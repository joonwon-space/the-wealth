# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/the_wealth

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 master key, 32 bytes hex)
ENCRYPTION_MASTER_KEY=change-me-use-openssl-rand-hex-32

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://joonwon.dev

# Cookie domain for cross-subdomain auth (e.g. ".joonwon.dev" in prod, leave empty for localhost)
COOKIE_DOMAIN=.joonwon.dev

# KIS API (한국투자증권 OpenAPI)
# APP_KEY/SECRET은 DB(kis_accounts 테이블)에 AES-256 암호화하여 저장
KIS_BASE_URL=https://openapi.koreainvestment.com:9443

# KIS rate limiting — 실전투자 정책: 1초 18건, /oauth2/tokenP 1초 1건
KIS_RATE_LIMIT_PER_SEC=5.0
KIS_RATE_LIMIT_BURST=15
KIS_TOKEN_RATE_LIMIT_PER_SEC=1.0
KIS_TOKEN_RATE_LIMIT_BURST=1
KIS_HTTP_MAX_RETRIES=1

# Internal system secret (used by backup-postgres.sh to call /internal/backup-status)
# Generate with: openssl rand -hex 32
# Leave empty to disable internal endpoints.
INTERNAL_SECRET=

# Sentry DSN for error tracking (leave empty to disable)
SENTRY_DSN=

# Deployment environment name sent to Sentry (production / staging / development)
ENVIRONMENT=production

# File logging (RotatingFileHandler). Leave empty to disable file logging (stdout only).
# In Docker, this is set to /var/log/the-wealth via docker-compose.yml.
LOG_DIR=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Cloudflare R2 backup storage (leave empty to skip remote upload)
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=the-wealth-backup
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Visual QA / E2E testing credentials
VISUAL_QA_EMAIL=qa@example.com
VISUAL_QA_PASSWORD=yourpassword

# Web Push (VAPID) — leave empty to disable push delivery
# Generate keys with: `python -c "from py_vapid import Vapid; v = Vapid(); v.generate_keys(); v.save_key('vapid.pem'); print(v.private_pem().decode()); print(v.public_pem().decode())"`
# VAPID_PUBLIC_KEY and VAPID_PRIVATE_KEY are URL-safe base64 raw strings.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@joonwon.dev
