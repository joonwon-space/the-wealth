# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/the_wealth

# JWT
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (AES-256 master key, 32 bytes hex)
ENCRYPTION_MASTER_KEY=change-me-use-openssl-rand-hex-32

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,https://joonwon.dev

# Cookie domain for cross-subdomain auth (e.g. ".joonwon.dev" in prod, leave empty for localhost)
COOKIE_DOMAIN=.joonwon.dev

# KIS API (한국투자증권 OpenAPI)
# APP_KEY/SECRET은 DB(kis_accounts 테이블)에 AES-256 암호화하여 저장
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
