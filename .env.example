# Root .env — used by docker-compose for variable interpolation.
# Copy to .env and fill in values.

# Sentry DSN (injected as a Next.js build arg in docker-compose.yml)
NEXT_PUBLIC_SENTRY_DSN=

# Dozzle log viewer credentials (http://localhost:9999 via SSH tunnel)
DOZZLE_USERNAME=admin
DOZZLE_PASSWORD=
